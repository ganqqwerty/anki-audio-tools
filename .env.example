# Copy to .env and edit. .env is gitignored.
# Override if Anki is at a non-standard location (auto-detected otherwise).
#
# macOS:   ANKI_PYTHON=$HOME/Library/Application Support/AnkiProgramFiles/.venv/bin/python3
# Linux:   ANKI_PYTHON=$HOME/.local/share/AnkiProgramFiles/.venv/bin/python3
# Windows: ANKI_PYTHON=%APPDATA%/AnkiProgramFiles/.venv/Scripts/python.exe
# ANKI_PYTHON=
