{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CommunicationContracts",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "settingsSavePayload": { "$ref": "#/definitions/SettingsSavePayload" },
    "asyncCommand": { "$ref": "#/definitions/AsyncCommand" },
    "asyncProgressPayload": { "$ref": "#/definitions/AsyncProgressPayload" },
    "asyncDonePayload": { "$ref": "#/definitions/AsyncDonePayload" },
    "frontendLogPayload": { "$ref": "#/definitions/FrontendLogPayload" },
    "copySupportReportPayload": { "$ref": "#/definitions/CopySupportReportPayload" },
    "saveErrorPayload": { "$ref": "#/definitions/SaveErrorPayload" },
    "healthReport": { "$ref": "#/definitions/HealthReport" },
    "runtimeStatus": { "$ref": "#/definitions/RuntimeStatus" },
    "initialState": { "$ref": "#/definitions/InitialState" },
    "prosodyPayload": { "$ref": "#/definitions/ProsodyPayload" },
    "showLogFileResult": { "$ref": "#/definitions/ShowLogFileResult" },
    "supportReportResult": { "$ref": "#/definitions/SupportReportResult" },
    "batchInitialState": { "$ref": "#/definitions/BatchInitialState" },
    "batchStartRequest": { "$ref": "#/definitions/BatchStartRequest" },
    "batchProgressPayload": { "$ref": "#/definitions/BatchProgressPayload" },
    "batchLogPayload": { "$ref": "#/definitions/BatchLogPayload" },
    "batchFinishPayload": { "$ref": "#/definitions/BatchFinishPayload" },
    "batchErrorPayload": { "$ref": "#/definitions/BatchErrorPayload" }
  },
  "definitions": {
    "Config": {
      "$comment": "Replaced by scripts/generate_contracts.py from addon/anki_audio_quick_editor/config.schema.json before quicktype runs.",
      "type": "object"
    },
    "JsonValue": {
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        {
          "type": "array",
          "items": {}
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "SettingsSavePayload": {
      "$ref": "#/definitions/Config"
    },
    "DiagnosticsState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["addon_id", "collection_available", "release_info", "runtime"],
      "properties": {
        "addon_id": { "type": "string" },
        "collection_available": { "type": "boolean" },
        "release_info": { "$ref": "#/definitions/ReleaseInfo" },
        "runtime": { "$ref": "#/definitions/RuntimeStatus" }
      }
    },
    "ReleaseInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit_hash", "commit_message"],
      "properties": {
        "commit_hash": { "type": "string" },
        "commit_message": { "type": "string" }
      }
    },
    "InitialState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config",
        "version",
        "addon_dir",
        "log_file_path",
        "locale",
        "direction",
        "messages",
        "diagnostics"
      ],
      "properties": {
        "config": { "$ref": "#/definitions/Config" },
        "version": { "type": "string" },
        "addon_dir": { "type": "string" },
        "log_file_path": { "type": "string" },
        "locale": { "type": "string" },
        "direction": { "enum": ["ltr", "rtl"] },
        "messages": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "diagnostics": { "$ref": "#/definitions/DiagnosticsState" }
      }
    },
    "HealthCheckPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config"],
      "properties": {
        "config": { "$ref": "#/definitions/Config" }
      }
    },
    "SupportReportPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config"],
      "properties": {
        "config": { "$ref": "#/definitions/Config" }
      }
    },
    "ShowLogFilePayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "RuntimeStatusPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "RuntimeInstallPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "HealthCheckAsyncCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op", "payload"],
      "properties": {
        "id": { "type": "string" },
        "op": { "type": "string" },
        "payload": { "$ref": "#/definitions/HealthCheckPayload" }
      }
    },
    "SupportReportAsyncCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op", "payload"],
      "properties": {
        "id": { "type": "string" },
        "op": { "type": "string" },
        "payload": { "$ref": "#/definitions/SupportReportPayload" }
      }
    },
    "ShowLogFileAsyncCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op", "payload"],
      "properties": {
        "id": { "type": "string" },
        "op": { "type": "string" },
        "payload": { "$ref": "#/definitions/ShowLogFilePayload" }
      }
    },
    "RuntimeStatusAsyncCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op", "payload"],
      "properties": {
        "id": { "type": "string" },
        "op": { "type": "string" },
        "payload": { "$ref": "#/definitions/RuntimeStatusPayload" }
      }
    },
    "RuntimeInstallAsyncCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op", "payload"],
      "properties": {
        "id": { "type": "string" },
        "op": { "type": "string" },
        "payload": { "$ref": "#/definitions/RuntimeInstallPayload" }
      }
    },
    "AsyncCommand": {
      "oneOf": [
        { "$ref": "#/definitions/HealthCheckAsyncCommand" },
        { "$ref": "#/definitions/SupportReportAsyncCommand" },
        { "$ref": "#/definitions/ShowLogFileAsyncCommand" },
        { "$ref": "#/definitions/RuntimeStatusAsyncCommand" },
        { "$ref": "#/definitions/RuntimeInstallAsyncCommand" }
      ]
    },
    "AsyncProgressPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "progress", "message"],
      "properties": {
        "id": { "type": "string" },
        "progress": { "type": "integer" },
        "message": { "type": "string" }
      }
    },
    "ExternalToolHealth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "path", "source", "version", "error"],
      "properties": {
        "available": { "type": "boolean" },
        "path": { "type": "string" },
        "source": { "type": "string", "enum": ["", "config", "managed", "bundled", "PATH"] },
        "version": { "type": "string" },
        "error": { "type": "string" }
      }
    },
    "RuntimeStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "runtime_manifest_id", "platform", "runtime_root", "progress", "message", "error"],
      "properties": {
        "phase": { "enum": ["ready", "missing", "downloading", "error", "unsupported"] },
        "runtime_manifest_id": { "type": "string" },
        "platform": { "type": "string" },
        "runtime_root": { "type": "string" },
        "progress": { "type": "integer" },
        "message": { "type": "string" },
        "error": { "type": "string" }
      }
    },
    "HealthReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collection_available", "deck_count", "note_type_count", "card_count"],
      "properties": {
        "collection_available": { "type": "boolean" },
        "deck_count": { "type": "integer" },
        "note_type_count": { "type": "integer" },
        "card_count": { "type": "integer" },
        "deep_filter": { "$ref": "#/definitions/ExternalToolHealth" },
        "rnnoise": { "$ref": "#/definitions/ExternalToolHealth" },
        "dpdfnet": { "$ref": "#/definitions/ExternalToolHealth" },
        "spleeter": { "$ref": "#/definitions/ExternalToolHealth" },
        "silero_vad": { "$ref": "#/definitions/ExternalToolHealth" },
        "runtime": { "$ref": "#/definitions/RuntimeStatus" }
      }
    },
    "SupportReportResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reportText"],
      "properties": {
        "reportText": { "type": "string" }
      }
    },
    "ShowLogFileResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logFilePath"],
      "properties": {
        "logFilePath": { "type": "string" }
      }
    },
    "BatchOperationName": {
      "enum": ["graph", "convert", "denoise", "remove_pauses", "slower", "faster", "volume_down", "volume_up"]
    },
    "BatchParameterKind": {
      "enum": ["none", "speed", "volume", "pause", "denoise", "format"]
    },
    "BatchParameterName": {
      "enum": ["none", "speed_step", "volume_step_db", "pause_aggressiveness", "denoise_algorithm", "target_format"]
    },
    "BatchPauseAggressiveness": {
      "enum": ["gentle", "normal", "aggressive"]
    },
    "BatchPauseDetectionAlgorithm": {
      "enum": ["silencedetect", "silero_vad"]
    },
    "DenoiseAlgorithm": {
      "enum": ["standard", "rnnoise", "dpdfnet", "voice_only"]
    },
    "OutputFormat": {
      "enum": ["mp3", "m4a", "wav", "flac"]
    },
    "BatchDpdfnetAttnLimitDB": {
      "enum": [6.0, 12.0, 18.0]
    },
    "BatchOperationParameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "speed_step": { "type": "number" },
        "volume_step_db": { "type": "number" },
        "pause_aggressiveness": { "$ref": "#/definitions/BatchPauseAggressiveness" },
        "pause_detection_algorithm": { "$ref": "#/definitions/BatchPauseDetectionAlgorithm" },
        "pause_threshold": { "type": "number" },
        "pause_min_silence_seconds": { "type": "number" },
        "pause_min_speech_seconds": { "type": "number" },
        "pause_preprocess_denoise": { "type": "boolean" },
        "denoise_algorithm": { "$ref": "#/definitions/DenoiseAlgorithm" },
        "dpdfnet_attn_limit_db": { "$ref": "#/definitions/BatchDpdfnetAttnLimitDB" },
        "target_format": { "$ref": "#/definitions/OutputFormat" }
      }
    },
    "BatchOperationOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "label", "requires_target_field", "parameter_kind", "parameter_name"],
      "properties": {
        "operation": { "$ref": "#/definitions/BatchOperationName" },
        "label": { "type": "string" },
        "requires_target_field": { "type": "boolean" },
        "parameter_kind": { "$ref": "#/definitions/BatchParameterKind" },
        "parameter_name": { "$ref": "#/definitions/BatchParameterName" }
      }
    },
    "BatchFieldGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notetype_name", "fields"],
      "properties": {
        "notetype_name": { "type": "string" },
        "fields": { "type": "array", "items": { "type": "string" } }
      }
    },
    "BatchDefaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "speed_step",
        "volume_step_db",
        "pause_aggressiveness",
        "pause_detection_algorithm",
        "pause_silencedetect_threshold_db",
        "pause_silencedetect_min_silence_seconds",
        "pause_silencedetect_min_speech_seconds",
        "pause_silencedetect_preprocess_denoise",
        "pause_silero_threshold",
        "pause_silero_min_silence_seconds",
        "pause_silero_min_speech_seconds",
        "pause_silero_preprocess_denoise",
        "denoise_algorithm",
        "dpdfnet_attn_limit_db",
        "output_format"
      ],
      "properties": {
        "speed_step": { "type": "number" },
        "volume_step_db": { "type": "number" },
        "pause_aggressiveness": { "$ref": "#/definitions/BatchPauseAggressiveness" },
        "pause_detection_algorithm": { "$ref": "#/definitions/BatchPauseDetectionAlgorithm" },
        "pause_silencedetect_threshold_db": { "type": "number" },
        "pause_silencedetect_min_silence_seconds": { "type": "number" },
        "pause_silencedetect_min_speech_seconds": { "type": "number" },
        "pause_silencedetect_preprocess_denoise": { "type": "boolean" },
        "pause_silero_threshold": { "type": "number" },
        "pause_silero_min_silence_seconds": { "type": "number" },
        "pause_silero_min_speech_seconds": { "type": "number" },
        "pause_silero_preprocess_denoise": { "type": "boolean" },
        "denoise_algorithm": { "$ref": "#/definitions/DenoiseAlgorithm" },
        "dpdfnet_attn_limit_db": { "$ref": "#/definitions/BatchDpdfnetAttnLimitDB" },
        "output_format": { "$ref": "#/definitions/OutputFormat" }
      }
    },
    "BatchInitialState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["note_count", "operations", "field_groups", "defaults", "locale", "direction", "messages"],
      "properties": {
        "note_count": { "type": "integer" },
        "operations": { "type": "array", "items": { "$ref": "#/definitions/BatchOperationOption" } },
        "field_groups": { "type": "array", "items": { "$ref": "#/definitions/BatchFieldGroup" } },
        "defaults": { "$ref": "#/definitions/BatchDefaults" },
        "locale": { "type": "string" },
        "direction": { "enum": ["ltr", "rtl"] },
        "messages": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "BatchStartRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "source_field", "parameters"],
      "properties": {
        "operation": { "$ref": "#/definitions/BatchOperationName" },
        "source_field": { "type": "string" },
        "target_field": { "type": ["string", "null"] },
        "parameters": { "$ref": "#/definitions/BatchOperationParameters" }
      }
    },
    "BatchProgressPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["processed", "total", "current_audio", "failures", "message"],
      "properties": {
        "processed": { "type": "integer" },
        "total": { "type": "integer" },
        "current_audio": { "type": "string" },
        "failures": { "type": "integer" },
        "message": { "type": "string" }
      }
    },
    "BatchLogPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line"],
      "properties": {
        "line": { "type": "string" }
      }
    },
    "BatchFinishPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["processed", "total", "written", "skipped", "failures", "canceled", "summary"],
      "properties": {
        "processed": { "type": "integer" },
        "total": { "type": "integer" },
        "written": { "type": "integer" },
        "skipped": { "type": "integer" },
        "failures": { "type": "integer" },
        "canceled": { "type": "boolean" },
        "summary": { "type": "string" }
      }
    },
    "UserFacingError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": { "type": "string" }
      }
    },
    "BatchErrorPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message"],
      "properties": {
        "message": { "type": "string" },
        "recoverable": { "type": "boolean" },
        "user_error": { "$ref": "#/definitions/UserFacingError" }
      }
    },
    "AsyncSuccessPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ok", "result"],
      "properties": {
        "id": { "type": "string" },
        "ok": { "enum": [true] },
        "result": { "$ref": "#/definitions/JsonValue" }
      }
    },
    "AsyncFailurePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ok", "error"],
      "properties": {
        "id": { "type": "string" },
        "ok": { "enum": [false] },
        "error": { "type": "string" },
        "user_error": { "$ref": "#/definitions/UserFacingError" }
      }
    },
    "AsyncDonePayload": {
      "oneOf": [
        { "$ref": "#/definitions/AsyncSuccessPayload" },
        { "$ref": "#/definitions/AsyncFailurePayload" }
      ]
    },
    "FrontendLogPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "message"],
      "properties": {
        "level": { "enum": ["debug", "info", "warn", "error", "unknown"] },
        "message": { "type": "string" },
        "context": { "$ref": "#/definitions/JsonValue" },
        "scope": { "type": "string" },
        "stack": { "type": "string" },
        "filename": { "type": "string" },
        "lineno": { "type": "integer" },
        "colno": { "type": "integer" },
        "operation_id": { "type": "string" }
      }
    },
    "CopySupportReportPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": { "type": "string" }
      }
    },
    "SaveErrorPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error"],
      "properties": {
        "error": { "type": "string" },
        "user_error": { "$ref": "#/definitions/UserFacingError" }
      }
    },
    "ProsodyPointPayload": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": [
        { "type": "integer" },
        { "type": ["number", "null"] },
        { "type": "number" },
        { "type": "boolean" }
      ]
    },
    "ProsodyPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "durationMs",
        "pitchMinHz",
        "pitchMaxHz",
        "sourceFilename",
        "analyzerName",
        "points"
      ],
      "properties": {
        "durationMs": { "type": "integer" },
        "pitchMinHz": { "type": ["number", "null"] },
        "pitchMaxHz": { "type": ["number", "null"] },
        "sourceFilename": { "type": "string" },
        "analyzerName": { "type": "string" },
        "points": {
          "type": "array",
          "items": { "$ref": "#/definitions/ProsodyPointPayload" }
        }
      }
    }
  }
}
