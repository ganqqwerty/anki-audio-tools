{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Anki Audio Quick Editor Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_config_version",
    "enabled",
    "debug_logging",
    "show_ffmpeg_commands",
    "repeat_playback_by_default",
    "show_graph_by_default",
    "manual_trim_small_ms",
    "manual_trim_large_ms",
    "speed_step",
    "min_speed",
    "max_speed",
    "volume_step_db",
    "min_volume_db",
    "max_volume_db",
    "internal_pause_silence_threshold_db",
    "internal_pause_threshold_ms",
    "internal_pause_target_gap_ms",
    "output_format",
    "ffmpeg_path",
    "deep_filter_path",
    "deep_filter_post_filter"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "_config_version": {
      "type": "integer",
      "minimum": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "debug_logging": {
      "type": "boolean"
    },
    "show_ffmpeg_commands": {
      "type": "boolean"
    },
    "repeat_playback_by_default": {
      "type": "boolean"
    },
    "show_graph_by_default": {
      "type": "boolean"
    },
    "manual_trim_small_ms": {
      "type": "integer",
      "minimum": 1
    },
    "manual_trim_large_ms": {
      "type": "integer",
      "minimum": 1
    },
    "speed_step": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "min_speed": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "max_speed": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "volume_step_db": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "min_volume_db": {
      "type": "number"
    },
    "max_volume_db": {
      "type": "number"
    },
    "internal_pause_silence_threshold_db": {
      "type": "integer"
    },
    "internal_pause_threshold_ms": {
      "type": "integer",
      "minimum": 1
    },
    "internal_pause_target_gap_ms": {
      "type": "integer",
      "minimum": 1
    },
    "output_format": {
      "type": "string",
      "const": "mp3"
    },
    "ffmpeg_path": {
      "type": "string"
    },
    "deep_filter_path": {
      "type": "string"
    },
    "deep_filter_post_filter": {
      "type": "boolean"
    }
  }
}
