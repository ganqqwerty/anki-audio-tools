{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Anki Audio Quick Editor Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_config_version",
    "enabled",
    "debug_logging",
    "show_ffmpeg_commands",
    "repeat_playback_by_default",
    "repeat_pause_seconds",
    "share_target",
    "voice_recording_countdown_seconds",
    "show_graph_by_default",
    "visible_editor_buttons",
    "editor_button_modes",
    "graph_voice_range",
    "graph_recording_condition",
    "graph_smoothness",
    "graph_connect_short_dropouts_ms",
    "graph_voice_lock",
    "speed_step",
    "min_speed",
    "max_speed",
    "volume_step_db",
    "min_volume_db",
    "max_volume_db",
    "internal_pause_silence_threshold_db",
    "internal_pause_threshold_ms",
    "internal_pause_target_gap_ms",
    "pause_aggressiveness",
    "output_format",
    "ffmpeg_path",
    "deep_filter_post_filter",
    "dpdfnet_attn_limit_db",
    "denoise_algorithm",
    "pitch_hum_mode"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "_config_version": {
      "type": "integer",
      "minimum": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "debug_logging": {
      "type": "boolean"
    },
    "show_ffmpeg_commands": {
      "type": "boolean"
    },
    "repeat_playback_by_default": {
      "type": "boolean"
    },
    "repeat_pause_seconds": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    },
    "share_target": {
      "type": "string",
      "enum": ["catbox", "litterbox"]
    },
    "voice_recording_countdown_seconds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "show_graph_by_default": {
      "type": "boolean"
    },
    "visible_editor_buttons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "aqe:play",
          "aqe:analyze",
          "aqe:record-voice",
          "aqe:play-recording",
          "aqe:show-file",
          "aqe:share",
          "aqe:convert",
          "aqe:remove-pauses",
          "aqe:denoise-standard",
          "aqe:pitch-hum",
          "aqe:slower",
          "aqe:faster",
          "aqe:volume-down",
          "aqe:volume-up",
          "aqe:undo",
          "aqe:redo",
          "aqe:settings"
        ]
      },
      "uniqueItems": true
    },
    "editor_button_modes": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "aqe:play",
          "aqe:analyze",
          "aqe:record-voice",
          "aqe:play-recording",
          "aqe:show-file",
          "aqe:share",
          "aqe:convert",
          "aqe:remove-pauses",
          "aqe:denoise-standard",
          "aqe:pitch-hum",
          "aqe:slower",
          "aqe:faster",
          "aqe:volume-down",
          "aqe:volume-up",
          "aqe:undo",
          "aqe:redo",
          "aqe:settings"
        ]
      },
      "additionalProperties": {
        "type": "string",
        "enum": ["text", "icon"]
      }
    },
    "graph_voice_range": {
      "type": "string",
      "enum": ["bass", "low", "general", "high", "child"]
    },
    "graph_recording_condition": {
      "type": "string",
      "enum": ["auto", "very_noisy", "noisy", "normal", "clean", "studio"]
    },
    "graph_smoothness": {
      "type": "string",
      "enum": ["raw", "balanced", "smooth", "very_smooth"]
    },
    "graph_connect_short_dropouts_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 500
    },
    "graph_voice_lock": {
      "type": "string",
      "enum": ["loose", "balanced", "stable"]
    },
    "speed_step": {
      "type": "number",
      "minimum": 1.01,
      "maximum": 5
    },
    "min_speed": {
      "type": "number",
      "minimum": 0.2,
      "maximum": 5
    },
    "max_speed": {
      "type": "number",
      "minimum": 0.2,
      "maximum": 5
    },
    "volume_step_db": {
      "type": "number",
      "minimum": 1,
      "maximum": 40
    },
    "min_volume_db": {
      "type": "number",
      "minimum": -40,
      "maximum": 40
    },
    "max_volume_db": {
      "type": "number",
      "minimum": -40,
      "maximum": 40
    },
    "internal_pause_silence_threshold_db": {
      "type": "integer"
    },
    "internal_pause_threshold_ms": {
      "type": "integer",
      "minimum": 1
    },
    "internal_pause_target_gap_ms": {
      "type": "integer",
      "minimum": 1
    },
    "pause_aggressiveness": {
      "type": "string",
      "enum": ["gentle", "normal", "aggressive"]
    },
    "output_format": {
      "type": "string",
      "enum": ["mp3", "m4a", "wav", "flac"]
    },
    "ffmpeg_path": {
      "type": "string"
    },
    "deep_filter_post_filter": {
      "type": "boolean"
    },
    "dpdfnet_attn_limit_db": {
      "type": "number",
      "enum": [6.0, 12.0, 18.0]
    },
    "denoise_algorithm": {
      "type": "string",
      "enum": ["standard", "rnnoise", "dpdfnet", "voice_only"]
    },
    "pitch_hum_mode": {
      "type": "string",
      "enum": ["direct", "pitch_tier"]
    }
  }
}
